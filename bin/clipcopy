#!/usr/bin/env bash
#
# clipcopy - read stdin and copy it to the clipboard.
#
# Picks the best available backend for the current environment:
#   1. pbcopy        (macOS)
#   2. wl-copy       (Wayland)
#   3. xclip         (X11)
#   4. tmux buffer   (inside tmux, e.g. headless Pi over SSH)
#
# Exits non-zero with a short message on stderr if no backend works,
# so callers can fall back to printing the content.

set -eu

if command -v pbcopy >/dev/null 2>&1; then
  exec pbcopy
fi

if [ -n "${WAYLAND_DISPLAY:-}" ] && command -v wl-copy >/dev/null 2>&1; then
  exec wl-copy
fi

if [ -n "${DISPLAY:-}" ] && command -v xclip >/dev/null 2>&1; then
  exec xclip -selection clipboard
fi

if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
  exec tmux load-buffer -
fi

echo "clipcopy: no clipboard backend available" >&2
exit 1
